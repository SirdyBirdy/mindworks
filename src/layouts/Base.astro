---
import '../styles/global.css';
import settings from '../content/settings.json';

const {
  title = 'Mindworks Counselling',
  description = 'A small Pune-based therapy practice. Certified, supervised, queer-affirmative. Online sessions across India.'
} = Astro.props;

const waLink = `https://wa.me/${settings.whatsappNumber}`;
const waBook = `https://wa.me/${settings.whatsappNumber}?text=Hi%2C%20I%27d%20like%20to%20book%20a%20free%20discovery%20call.`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

<nav id="main-nav">
  <a href="/" class="nav-logo"><em>mind</em>works</a>
  <div class="nav-links">
    <a href="/therapists">Our therapists</a>
    <a href="/journal">Journal</a>
  </div>
  <a href={waBook} target="_blank" rel="noopener" class="nav-cta">
    Book free call
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
  </a>
  <button class="nav-hamburger" id="nav-toggle" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="nav-mobile" id="mobile-menu">
  <a href="/therapists">Our therapists</a>
  <a href="/journal">Journal</a>
  <a href={waBook} target="_blank" rel="noopener" class="mobile-cta">Book free call</a>
</div>

<slot />

<footer>
  <div class="f-top">
    <div class="f-brand-col">
      <div class="f-brand"><em>mind</em>works counselling</div>
      <p class="f-desc">A small Pune-based therapy practice.<br/>Certified, supervised, queer-affirmative.<br/>Online sessions across India.</p>
    </div>
    <div class="f-col">
      <div class="f-label">Services</div>
      <a href="/therapists">Individual therapy</a>
      <a href="/therapists">Couples counselling</a>
    </div>
    <div class="f-col">
      <div class="f-label">Navigate</div>
      <a href="/therapists">Our therapists</a>
      <a href="/journal">Journal</a>
    </div>
    <div class="f-col">
      <div class="f-label">Connect</div>
      <a href={waLink} target="_blank" rel="noopener">WhatsApp</a>
      <a href={settings.instagram} target="_blank" rel="noopener">Instagram</a>
      <a href={`tel:${settings.whatsappNumber}`}>{settings.phoneDisplay}</a>
    </div>
  </div>
  <div class="f-bottom">
    <span>© {new Date().getFullYear()} Mindworks Counselling</span>
    <span>Pune, India</span>
  </div>
</footer>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 40);
  });

  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('open');
  });

  if (window.netlifyIdentity) {
    window.netlifyIdentity.on('init', (user: any) => {
      if (!user) {
        window.netlifyIdentity.on('login', () => { document.location.href = '/admin/'; });
      }
    });
  }
</script>

</body>
</html>

<style>
#main-nav {
  position: sticky; top: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.1rem 2.5rem;
  background: rgba(247,243,236,0.9);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
}
.nav-logo {
  font-family: var(--font-display); font-size: 1.15rem;
  font-style: italic; color: var(--ink);
}
.nav-logo em { color: var(--teal); }
.nav-links { display: flex; gap: 2rem; }
.nav-links a { font-size: 0.8rem; color: var(--slate); transition: color 0.2s; }
.nav-links a:hover { color: var(--ink); }
.nav-cta {
  display: inline-flex; align-items: center; gap: 0.4rem;
  background: var(--clay); color: #fff;
  padding: 0.55rem 1.2rem; border-radius: 100px;
  font-size: 0.78rem; font-weight: 500; transition: background 0.2s;
}
.nav-cta:hover { background: var(--ink); }
.nav-cta svg { width: 13px; height: 13px; transition: transform 0.2s; }
.nav-cta:hover svg { transform: translate(2px,-2px); }
.nav-hamburger { display: none; flex-direction: column; gap: 4px; background: none; border: none; cursor: pointer; padding: 4px; }
.nav-hamburger span { display: block; width: 22px; height: 1.5px; background: var(--ink); }
.nav-mobile { display: none; flex-direction: column; gap: 1rem; padding: 1.5rem 1.25rem; background: var(--cream); border-bottom: 1px solid var(--border); }
.nav-mobile.open { display: flex; }
.nav-mobile a { font-size: 1rem; color: var(--slate); }
.mobile-cta { background: var(--clay); color: #fff !important; padding: 0.75rem 1.25rem; border-radius: 100px; text-align: center; margin-top: 0.5rem; }

footer { background: var(--ink); }
.f-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 2rem; padding: 3.5rem 2.5rem; }
.f-brand { font-family: var(--font-display); font-size: 1.1rem; font-style: italic; color: var(--cream); margin-bottom: 0.75rem; }
.f-brand em { color: var(--clay); }
.f-desc { font-size: 0.78rem; color: rgba(247,243,236,0.35); line-height: 1.75; }
.f-label { font-size: 0.62rem; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(247,243,236,0.25); margin-bottom: 1rem; }
footer a { display: block; font-size: 0.82rem; color: rgba(247,243,236,0.45); line-height: 2.1; transition: color 0.2s; }
footer a:hover { color: var(--cream); }
.f-bottom { border-top: 1px solid rgba(247,243,236,0.06); padding: 1.25rem 2.5rem; display: flex; justify-content: space-between; font-size: 0.68rem; color: rgba(247,243,236,0.2); }

@media (max-width: 768px) {
  #main-nav { padding: 1rem 1.25rem; }
  .nav-links { display: none; }
  .nav-cta { display: none; }
  .nav-hamburger { display: flex; }
  .f-top { grid-template-columns: 1fr 1fr; padding: 2.5rem 1.25rem; }
  .f-brand-col { grid-column: span 2; }
  .f-bottom { padding: 1rem 1.25rem; flex-direction: column; gap: 0.5rem; }
}
</style>
